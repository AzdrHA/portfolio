datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model programming_language {
  id String @id @default(cuid())
  name String @unique
  link String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model experience {
	id String @id @default(cuid())

	name String
	where String
	date String
	description String

	createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model link {
	id String @id @default(cuid())

	name String
	link String
}

model Stack {
	id String @id @default(cuid())

	name String
	link String
}
